# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        colors = true
        interval = 5
}

order += "disk /"
order += "disk /home"
order += "memory"
order += "run_watch DHCP"
order += "path_exists VPN"
order += "wireless _first_"
order += "ethernet _first_"
order += "battery 0"
#order += "cpu_temperature 0"
#order += "load"
order += "volume master"
order += "tztime local"

wireless _first_ {
        format_up = "W: (%quality at %essid) %ip"
        format_down = "W: down"
}

ethernet _first_ {
        # if you use %speed, i3status requires root privileges
        format_up = "E: %ip (%speed)"
        format_down = "E: down"
}

battery 0 {
        format = "%status %percentage %remaining %emptytime"
        format_down = "No battery"
        status_chr = "⚡ CHR"
        status_bat = "🔋 BAT"
        status_unk = "? UNK"
        status_full = "☻ FULL"
        path = "/sys/class/power_supply/BAT%d/uevent"
        low_threshold = 10
}

run_watch DHCP {
        pidfile = "/var/run/dhclient*.pid"
}

path_exists VPN {
	path = "/proc/sys/net/ipv4/conf/tun0"
}

tztime local {
        format = "%Y-%m-%d (%U) %H:%M:%S"
}

memory {
        format = "RAM: F=%free A=%available (U: %used) / %total \t"
        format_degraded = "RAM: F=%free A=%available (U: %used) / %total \t"
        threshold_degraded = "13%"
        threshold_critical = "5%"
}

load {
        format = "%1min"
}

disk "/" {
        format = "HDD: %avail"
        format_below_threshold = "W: HDD: %avail"
        threshold_type = "percentage_free"
        low_threshold = "15"
}

disk "/home" {
        format = "HOME: %avail \t"
        format_below_threshold = "W: HOME: %avail \t"
        threshold_type = "percentage_free"
        low_threshold = "15"
}

volume master {
	format = "♪: %volume"
	format_muted = "♪: muted (%volume)"
	device = "default"
	mixer = "Master"
	mixer_idx = 0
}
